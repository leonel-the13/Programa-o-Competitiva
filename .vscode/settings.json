{
  "C_Cpp.errorSquiggles": "enabled",
  "files.associations": {
    "*.cpp": "cpp",
    "iostream": "cpp",
    "vector": "cpp",
    "string": "cpp",
    "algorithm": "cpp",
    "map": "cpp",
    "set": "cpp",
    "queue": "cpp",
    "stack": "cpp",
    "unordered_map": "cpp",
    "unordered_set": "cpp",
    "bits/stdc++.h": "cpp"
  },
  "C_Cpp.default.cppStandard": "c++17",
  "C_Cpp.default.compilerPath": "/usr/bin/clang++",
  "[cpp]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.formatOnSave": false
  }
}
